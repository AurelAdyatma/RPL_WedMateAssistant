<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.rplbo.app.rpl_wedmateassistant.controller.LoginController"
           style="-fx-background-color: #d9e2f2;">

    <children>
        <VBox alignment="CENTER"
              spacing="12"
              maxWidth="320"
              prefWidth="320"
              style="-fx-background-color: white;
                     -fx-border-color: black;
                     -fx-border-width: 1;
                     -fx-padding: 25;">

            <Label text="WedMate Assistant"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField fx:id="txtUsername"
                       promptText="Username"
                       prefWidth="250"
                       maxWidth="250"
                       style="-fx-pref-height: 35;
                              -fx-background-color: white;
                              -fx-border-color: black;
                              -fx-border-width: 1;" />

            <PasswordField fx:id="txtPassword"
                           promptText="Password"
                           prefWidth="250"
                           maxWidth="250"
                           style="-fx-pref-height: 35;
                                  -fx-background-color: white;
                                  -fx-border-color: black;
                                  -fx-border-width: 1;" />

            <Label fx:id="lblError"
                   text=""
                   visible="false"
                   managed="false"
                   wrapText="true"
                   style="-fx-text-fill: red; -fx-font-size: 12px;" />

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="btnKembali"
                        text="Kembali"
                        onAction="#handleKembali"
                        prefWidth="110"
                        style="-fx-pref-height: 35;
                               -fx-background-color: #E2E8F0;
                               -fx-text-fill: black;
                               -fx-font-weight: bold;
                               -fx-border-color: black;
                               -fx-border-width: 1;
                               -fx-cursor: hand;" />
                <Button fx:id="btnLogin"
                        text="Masuk"
                        onAction="#handleLogin"
                        prefWidth="110"
                        style="-fx-pref-height: 35;
                               -fx-background-color: white;
                               -fx-text-fill: black;
                               -fx-font-weight: bold;
                               -fx-border-color: black;
                               -fx-border-width: 1;
                               -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </children>
</StackPane>
