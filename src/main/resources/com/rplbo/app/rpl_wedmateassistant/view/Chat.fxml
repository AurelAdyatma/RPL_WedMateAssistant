<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Chat.fxml — Tampilan layar percakapan utama WedMate Assistant.
    Controller: com.rplbo.app.rpl_wedmateassistant.controller.ChatController
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rplbo.app.rpl_wedmateassistant.controller.ChatController"
            styleClass="chat-root">

    <!-- Header -->
    <top>
        <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="12">
            <Label text="💍 WedMate Assistant" styleClass="chat-header-title"/>
        </HBox>
    </top>

    <!-- Area percakapan -->
    <center>
        <ListView fx:id="listViewChat" styleClass="chat-list"/>
    </center>

    <!-- Input area -->
    <bottom>
        <HBox spacing="8" styleClass="chat-input-bar">
            <TextField fx:id="txtInputPesan"
                       promptText="Ketik pertanyaan Anda..."
                       styleClass="chat-input"
                       HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnKirim" text="Kirim" onAction="#handleKirimPesan"
                    styleClass="btn-primary"/>
        </HBox>
    </bottom>

</BorderPane>
