<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.Cursor?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.rplbo.app.rpl_wedmateassistant.controller.WelcomeController"
      alignment="CENTER" spacing="50"
      style="-fx-background-color: #FFFFFF; -fx-padding: 50;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="8">
        <Label text="Welcome to WedMate" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #111820;"/>
        <Label text="Your Assistent for Weeding Dress" style="-fx-font-size: 16px; -fx-text-fill: #9CA3AF;"/>
    </VBox>

    <!-- Cards -->
    <HBox alignment="CENTER" spacing="30">
        
        <!-- Card User -->
        <VBox alignment="CENTER" spacing="20" prefWidth="350" prefHeight="280"
              style="-fx-background-color: #F4F9FD; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-border-width: 1;"
              onMouseClicked="#handleUserClick">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
            <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                <Label text="👩‍💻" style="-fx-font-size: 90px;"/>
            </VBox>
            <HBox alignment="CENTER" style="-fx-padding: 0 0 25 0;">
                <Label text="Login sebagai " style="-fx-font-size: 16px; -fx-text-fill: #4B5563;"/>
                <Label text="User" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111820;"/>
            </HBox>
        </VBox>

        <!-- Card Admin -->
        <VBox alignment="CENTER" spacing="20" prefWidth="350" prefHeight="280"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-border-width: 1;"
              onMouseClicked="#handleAdminClick">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
            <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                <Label text="👨‍💼" style="-fx-font-size: 90px;"/>
            </VBox>
            <HBox alignment="CENTER" style="-fx-padding: 0 0 25 0;">
                <Label text="Login sebagai " style="-fx-font-size: 16px; -fx-text-fill: #4B5563;"/>
                <Label text="Admin" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111820;"/>
            </HBox>
        </VBox>

    </HBox>

</VBox>
